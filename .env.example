# Server
PORT=3001
NODE_ENV=development

# Wix App Credentials (from Wix Dev Center)
WIX_APP_ID=your_wix_app_id
WIX_APP_SECRET=your_wix_app_secret
WIX_WEBHOOK_SECRET=your_wix_webhook_hmac_secret

# HubSpot OAuth (from HubSpot Developer Portal)
HUBSPOT_CLIENT_ID=your_hubspot_client_id
HUBSPOT_CLIENT_SECRET=your_hubspot_client_secret
HUBSPOT_REDIRECT_URI=your redirect url here
HUBSPOT_APP_ID=your_hubspot_numeric_app_id

# Token encryption (generate: openssl rand -hex 32)
ENCRYPTION_KEY=your_64_char_hex_string_here

# Frontend URL for OAuth redirects
FRONTEND_URL=your frontend_url_here

# SQLite database path
DB_PATH=./data/integration.db

# MongoDB connection string (replace with your actual credentials)
MONGODB_URI=your_mongodb_connection_string_here